<Window x:Class="system_zawodnicy_zimowi.wpfAPP.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Panel Logowania" 
        Height="550" 
        Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Grid Background="#F0F0F0">
        <StackPanel VerticalAlignment="Center" Margin="40">

            <TextBlock Text="Witaj w Systemie" FontSize="24" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,0,0,20" Foreground="#333"/>

            <TextBlock Text="Login:" Margin="0,5,0,0"/>
            <TextBox x:Name="txtLogin" Height="30" Padding="5"/>

            <TextBlock Text="Hasło:" Margin="0,10,0,0"/>
            <PasswordBox x:Name="txtHaslo" Height="30" Padding="5"/>

            <Button Content="Zaloguj się" Height="40" Margin="0,20,0,0" 
                    Click="BtnZaloguj_Click" Background="#4CAF50" Foreground="White" FontWeight="Bold"/>
            <TextBlock Text="Kod Administratora (tylko do rejestracji):" Margin="0,10,0,0"/>
            <PasswordBox x:Name="txtKodAuth" Height="30" Padding="5"/>
            
            <Button Content="Zarejestruj nowego admina" Height="30" Margin="0,10,0,0" 
                    Click="BtnRejestruj_Click" Background="#2196F3" Foreground="White"/>

            <TextBlock x:Name="lblKomunikat" Foreground="Red" 
                       HorizontalAlignment="Center" Margin="0,15,0,0" TextWrapping="Wrap"/>

        </StackPanel>
    </Grid>
</Window>