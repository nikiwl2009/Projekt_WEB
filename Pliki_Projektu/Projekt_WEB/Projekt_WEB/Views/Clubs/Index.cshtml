@model IEnumerable<Projekt_WEB.Models.Club>

@{
    ViewData["Title"] = "Kluby";
}

<section class="container mt-4">
    <div class="mb-4">
        <h1>Kluby</h1>
        <p class="text-muted">
            Publiczna lista klubów sportów zimowych z podsumowaniem zawodników i punktów.
        </p>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            Brak klubów do wyświetlenia.
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var club in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <article class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h2 class="h5">@club.Name</h2>

                            <p class="text-muted mb-2">
                                @club.City, @club.Country
                            </p>

                            <p>@club.Description</p>

                            <p class="mb-1">
                                <strong>Zawodnicy:</strong> @club.Athletes.Count
                            </p>

                            <p class="mb-3">
                                <strong>Łączne punkty:</strong> @club.Athletes.Sum(a => a.Points)
                            </p>

                            <a asp-controller="Clubs"
                               asp-action="Details"
                               asp-route-id="@club.ClubId"
                               class="btn btn-outline-primary">
                                Szczegóły klubu
                            </a>
                        </div>
                    </article>
                </div>
            }
        </div>
    }
</section>