<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Winter Sports Manager</title>
    <link rel="icon" type="image/png" href="~/snieg.png" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="scroll-progress" aria-hidden="true"></div>

    <header class="site-header">
        <a class="brand" asp-controller="Home" asp-action="Index">
            <span class="brand-mark">❄</span>
            <span>Winter Sports Manager</span>
        </a>

        <button class="nav-toggle" type="button" aria-label="Otwórz menu">☰</button>

        <nav class="main-nav" aria-label="Nawigacja główna">
            <a asp-area="" asp-controller="Home" asp-action="Index">Start</a>
            <a asp-area="" asp-controller="Athletes" asp-action="Index">Zawodnicy</a>
            <a asp-area="" asp-controller="Clubs" asp-action="Index">Kluby</a>
            <a asp-area="" asp-controller="Disciplines" asp-action="Index">Dyscypliny</a>
            <a asp-area="" asp-controller="Results" asp-action="Index">Wyniki</a>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Panel admina</a>
                <form class="logout-form" asp-controller="Account" asp-action="Logout" method="post">
                    <button type="submit">Wyloguj</button>
                </form>
            }
            else
            {
                <a asp-area="" asp-controller="Account" asp-action="Login">Logowanie</a>
            }
            <button class="theme-toggle" type="button" aria-label="Zmień motyw">◐</button>
        </nav>
    </header>

    @if (TempData["Toast"] != null)
    {
        <div class="toast-message" role="status">@TempData["Toast"]</div>
    }

    <main>
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div>
            <strong>Winter Sports Manager</strong>
            <p>System zarządzania zawodnikami sportów zimowych.</p>
        </div>
        <div>
            <a asp-controller="Athletes" asp-action="ExportCsv">Eksport CSV</a>
            <span>Projekt MVC · ASP.NET Core · EF Core · SQLite/AGH/ Zespół: Szymon Z, Nikodem W, Natalia G, Franciszek T.</span>
        </div>
    </footer>

    <button class="back-to-top" type="button" aria-label="Powrót na górę">↑</button>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
