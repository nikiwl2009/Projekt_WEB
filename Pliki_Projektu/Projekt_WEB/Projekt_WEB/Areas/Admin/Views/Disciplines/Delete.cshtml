@model Projekt_WEB.Models.Discipline

@{
    ViewData["Title"] = "Usuń dyscyplinę";
}

<section class="container mt-4">
    <h1>Usuń dyscyplinę</h1>

    <div class="alert alert-warning">
        Czy na pewno chcesz usunąć tę dyscyplinę?
        Jeżeli dyscyplina ma przypisanych zawodników albo zawody, usunięcie zostanie zablokowane.
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <h2 class="h4">@Model.Name</h2>

            <p><strong>Opis:</strong> @Model.Description</p>
            <p><strong>Liczba zawodników:</strong> @(Model.Athletes != null ? Model.Athletes.Count : 0)</p>
            <p><strong>Liczba zawodów:</strong> @(Model.CompetitionEvents != null ? Model.CompetitionEvents.Count : 0)</p>

            <form asp-area="Admin"
                  asp-controller="Disciplines"
                  asp-action="Delete"
                  asp-route-id="@Model.DisciplineId"
                  method="post">

                <button type="submit" class="btn btn-danger">Usuń</button>

                <a asp-area="Admin" asp-controller="Disciplines" asp-action="Index" class="btn btn-outline-secondary">
                    Anuluj
                </a>
            </form>
        </div>
    </div>
</section>