@model dynamic

@{
    ViewData["Title"] = "Dashboard Statystyk";
}

<section class="section-block reveal">
    <div style="margin-bottom: 2rem;">
        <span class="eyebrow">Analiza</span>
        <h1>Statystyki</h1>
        <p class="hero-copy">Statystyki zawodników, punktów oraz popularności dyscyplin zimowych w systemie.</p>
    </div>


        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(min(100%, 350px), 1fr)); gap: 1.5rem; margin-bottom: 3rem;">

            <div class="ice-panel chart-card" style="position: relative; padding-bottom: 2rem; min-width: 0; overflow: hidden;">
                <h2 style="text-align: center; margin-bottom: 1rem; color: var(--ice);">Zawodnicy wg Dyscypliny</h2>
                <div style="position: relative; height: 320px; width: 100%; display: flex; justify-content: center;">
                <canvas id="disciplineChart">
                    Wykres kołowy pokazujący ilość zawodników w poszczególnych dyscyplinach zimowych.
                </canvas>

                </div>
            </div>

            <div class="ice-panel chart-card" style="position: relative; padding-bottom: 2rem; min-width: 0; overflow: hidden;">
                <h2 style="text-align: center; margin-bottom: 1rem; color: var(--ice);">Top 10 Zawodników wg Punktów</h2>
                <div style="position: relative; height: 320px; width: 100%;">
                <canvas id="topChart">
                    Wykres słupkowy prezentujący Top 10 zawodników z największą ilością punktów.
                </canvas>

                </div>
            </div>

        </div>


</section>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        window.chartData = @Html.Raw(Json.Serialize(Model));
        
        document.addEventListener("DOMContentLoaded", function () {
            if (typeof window.initPublicCharts === 'function') {
                window.initPublicCharts();
            }
        });
    </script>
}
