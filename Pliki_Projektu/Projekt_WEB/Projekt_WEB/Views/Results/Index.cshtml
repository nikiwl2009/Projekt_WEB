@model IEnumerable<Projekt_WEB.Models.Result>

@{
    ViewData["Title"] = "Wyniki";
}

<section class="section-block reveal">
    <div style="margin-bottom: 2rem;">
        <span class="eyebrow">Klasyfikacja</span>
        <h1>Wyniki Zawodów</h1>
        <p class="hero-copy">
            Publiczny podgląd wyników i osiągnięć zawodników we wszystkich rozegranych zawodach sportów zimowych.
        </p>
    </div>

    <form asp-action="Index" method="get" class="filter-bar reveal" style="margin-bottom: 3rem;">
        <div>
            <select id="disciplineId" name="disciplineId" asp-items="ViewBag.Disciplines">
                <option value="">Wszystkie dyscypliny</option>
            </select>
        </div>

        <div>
            <select id="eventId" name="eventId" asp-items="ViewBag.Events">
                <option value="">Wszystkie zawody</option>
            </select>
        </div>

        <div>
            <select id="sort" name="sort">
                <option value="">Data rosnąco + miejsce</option>
                <option value="date_desc">Data malejąco</option>
                <option value="date_asc">Data rosnąco</option>
                <option value="place_desc">Miejsce malejąco</option>
                <option value="points_desc">Punkty malejąco</option>
                <option value="points_asc">Punkty rosnąco</option>
            </select>
        </div>

        <div>
            <button type="submit" class="btn btn-primary" style="width: 100%; height: 100%;">Filtruj</button>
        </div>
    </form>

    @if (!Model.Any())
    {
        <div class="ice-panel reveal" style="text-align: center; padding: 4rem 2rem;">
            <div style="font-size: 3rem; margin-bottom: 1rem; color: var(--ice);">🏆</div>
            <h2 style="margin-top: 0;">Brak wyników</h2>
            <p style="color: var(--muted);">Nie znaleziono wyników spełniających wybrane kryteria filtru.</p>
        </div>
    }
    else
    {
        <div class="ice-panel table-wrapper reveal" style="padding: 0; overflow: hidden;">
            <table style="margin: 0;">
                <thead style="background: rgba(255,255,255,0.03);">
                    <tr>
                        <th>Zawodnik</th>
                        <th>Zawody</th>
                        <th>Data</th>
                        <th>Miejsce zawodów</th>
                        <th>Pozycja</th>
                        <th>Punkty</th>
                        <th>Wynik czasowy/punktowy</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var result in Model)
                    {
                        <tr>
                            <td style="font-weight: bold;">
                                @if (result.Athlete != null)
                                {
                                    <a asp-controller="Athletes"
                                       asp-action="Details"
                                       asp-route-id="@result.Athlete.AthleteId"
                                       style="text-decoration: underline; color: var(--text);">
                                        @result.Athlete.FirstName @result.Athlete.LastName
                                    </a>
                                }
                                else
                                {
                                    <span style="color: var(--muted);">Brak danych</span>
                                }
                            </td>

                            <td>
                                <strong>@(result.CompetitionEvent != null ? result.CompetitionEvent.Name : "Brak danych")</strong><br />
                                <small style="color: var(--muted);">@(result.CompetitionEvent?.Discipline != null ? result.CompetitionEvent.Discipline.Name : "-")</small>
                            </td>

                            <td style="white-space: nowrap; color: var(--ice);">
                                @(result.CompetitionEvent != null ? result.CompetitionEvent.EventDate.ToString("dd.MM.yyyy") : "-")
                            </td>

                            <td>
                                @if (result.CompetitionEvent != null)
                                {
                                    <span>
                                        @result.CompetitionEvent.VenueName<br />
                                        <small style="color: var(--muted);">@result.CompetitionEvent.City, @result.CompetitionEvent.Country</small>
                                    </span>
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </td>

                            <td style="font-size: 1.1rem;">
                                @if (result.Place == 1)
                                {
                                    <span style="color: #facc15; font-weight: 900;">🥇 1</span>
                                }
                                else if (result.Place == 2)
                                {

                                    <span style="color: #cbd5e1; font-weight: 900;">🥈 2</span>
                                }
                                else if (result.Place == 3)
                                {

                                    <span style="color: #b45309; font-weight: 900;">🥉 3</span>
                                }
                                else
                                {

                                    <span>@result.Place</span>
                                }
                            </td>

                            <td><span class="pill">@result.Points pkt</span></td>

                            <td style="font-family: monospace; font-size: 1.1rem;">@result.ScoreText</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

<script>
    const sortSelect = document.getElementById("sort");
    if (sortSelect) {
        sortSelect.value = "@ViewBag.Sort";
    }
</script>