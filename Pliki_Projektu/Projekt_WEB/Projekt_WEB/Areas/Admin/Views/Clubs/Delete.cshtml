@model Projekt_WEB.Models.Club

@{
    ViewData["Title"] = "Usuń klub";
}

<section class="container mt-4">
    <h1>Usuń klub</h1>

    <div class="alert alert-warning">
        Czy na pewno chcesz usunąć ten klub?
        Jeżeli klub ma przypisanych zawodników, usunięcie zostanie zablokowane.
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <h2 class="h4">@Model.Name</h2>

            <p><strong>Miasto:</strong> @Model.City</p>
            <p><strong>Kraj:</strong> @Model.Country</p>
            <p><strong>Opis:</strong> @Model.Description</p>
            <p><strong>Liczba zawodników:</strong> @(Model.Athletes != null ? Model.Athletes.Count : 0)</p>

            <form asp-area="Admin" asp-controller="Clubs" asp-action="Delete" asp-route-id="@Model.ClubId" method="post">
                <button type="submit" class="btn btn-danger">Usuń</button>

                <a asp-area="Admin" asp-controller="Clubs" asp-action="Index" class="btn btn-outline-secondary">
                    Anuluj
                </a>
            </form>
        </div>
    </div>
</section>