@model Projekt_WEB.Models.Athlete

@{
    ViewData["Title"] = "Szczegóły zawodnika";
}

<section class="container mt-4">
    <a asp-action="Index" class="btn btn-outline-secondary mb-3">
        ← Powrót do listy
    </a>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-4 align-items-center">
                <div class="col-md-3 text-center">
                    @if (!string.IsNullOrWhiteSpace(Model.PhotoPath))
                    {
                        <img src="@Model.PhotoPath"
                             alt="Zdjęcie zawodnika @Model.FirstName @Model.LastName"
                             class="img-fluid rounded"
                             style="max-height: 180px;" />
                    }
                    else
                    {
                        <div class="border rounded p-4 text-muted">
                            Brak zdjęcia
                        </div>
                    }
                </div>

                <div class="col-md-9">
                    <h1>@Model.FirstName @Model.LastName</h1>

                    <p class="text-muted mb-2">
                        @(Model.Discipline != null ? Model.Discipline.Name : "Brak dyscypliny")
                    </p>

                    <div class="row">
                        <div class="col-sm-6 col-lg-3 mb-2">
                            <strong>Kraj:</strong><br />
                            @Model.Country
                        </div>

                        <div class="col-sm-6 col-lg-3 mb-2">
                            <strong>Klub:</strong><br />
                            @(Model.Club != null ? Model.Club.Name : "Brak klubu")
                        </div>

                        <div class="col-sm-6 col-lg-3 mb-2">
                            <strong>Wiek:</strong><br />
                            @Model.Age
                        </div>

                        <div class="col-sm-6 col-lg-3 mb-2">
                            <strong>Punkty:</strong><br />
                            @Model.Points
                        </div>
                    </div>

                    <p class="mb-0">
                        <strong>Status:</strong> @Model.Status
                    </p>
                </div>
            </div>
        </div>
    </div>

    <h2 class="h4 mb-3">Wyniki zawodnika</h2>

    @if (Model.Results == null || !Model.Results.Any())
    {
        <div class="alert alert-info">
            Ten zawodnik nie ma jeszcze zapisanych wyników.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th>Zawody</th>
                        <th>Data</th>
                        <th>Miejsce zawodów</th>
                        <th>Dyscyplina</th>
                        <th>Miejsce</th>
                        <th>Punkty</th>
                        <th>Wynik</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var result in Model.Results)
                    {
                        <tr>
                            <td>
                                @(result.CompetitionEvent != null ? result.CompetitionEvent.Name : "Brak danych")
                            </td>

                            <td>
                                @(result.CompetitionEvent != null ? result.CompetitionEvent.EventDate.ToString("dd.MM.yyyy") : "-")
                            </td>

                            <td>
                                @if (result.CompetitionEvent != null)
                                {
                                    <span>
                                        @result.CompetitionEvent.VenueName,
                                        @result.CompetitionEvent.City
                                    </span>
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </td>

                            <td>
                                @(result.CompetitionEvent?.Discipline != null ? result.CompetitionEvent.Discipline.Name : "-")
                            </td>

                            <td>@result.Place</td>
                            <td>@result.Points</td>
                            <td>@result.ScoreText</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>